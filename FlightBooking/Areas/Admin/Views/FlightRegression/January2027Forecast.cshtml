                </div>
            </div>

        </div>
    </div>
</main>

@section Scripts {
    <script>
        /* ── Filtre ── */
        function filterTable(type, btn) {
            document.querySelectorAll('.fc-chip').forEach(function(c){ c.classList.remove('active'); });
            btn.classList.add('active');

            var rows = document.querySelectorAll('#forecastTable tbody .fc-row');
            var visible = 0;

            rows.forEach(function(row) {
                var show = true;
                if (type === 'high')    show = row.dataset.demand   === 'high';
                if (type === 'medium')  show = row.dataset.demand   === 'medium';
                if (type === 'low')     show = row.dataset.demand   === 'low';
                if (type === 'weekend') show = row.dataset.weekend  === 'true';
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            document.getElementById('recordCount').textContent = visible + ' kayıt';
        }

        /* ── Arama ── */
        function searchTable(val) {
            var rows    = document.querySelectorAll('#forecastTable tbody .fc-row');
            var visible = 0;
            val = val.toLowerCase();

            rows.forEach(function(row) {
                var date = (row.dataset.date || '').toLowerCase();
                var show = val === '' || date.includes(val);
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            document.getElementById('recordCount').textContent = visible + ' kayıt';
        }

        /* ── Export CSV ── */
        function exportCSV() {
            var rows  = document.querySelectorAll('#forecastTable tbody .fc-row');
            var lines = ['Tarih,Morning Pax,Evening Pax,Load Factor,Talep'];

            rows.forEach(function(row) {
                if (row.style.display === 'none') return;
                var cells = row.querySelectorAll('td');
                var date  = row.dataset.date || '';
                var mPax  = cells[1] ? cells[1].textContent.trim().replace(/\s+/g,' ') : '';
                var ePax  = cells[2] ? cells[2].textContent.trim().replace(/\s+/g,' ') : '';
                var lf    = cells[3] ? cells[3].textContent.trim().replace(/\s+/g,' ') : '';
                var dem   = cells[4] ? cells[4].textContent.trim() : '';
                lines.push([date, mPax, ePax, lf, dem].join(','));
            });

            var blob = new Blob([lines.join('\n')], { type:'text/csv;charset=utf-8;' });
            var url  = URL.createObjectURL(blob);
            var a    = document.createElement('a');
            a.href   = url;
            a.download = 'ocak2027-tahmin.csv';
            a.click();
            URL.revokeObjectURL(url);
        }

        /* ── AI Report (demo) ── */
        function showAIReport() {
            alert('AI Forecast Report PDF olarak hazırlanıyor... (Demo)');
        }
    </script>
}


