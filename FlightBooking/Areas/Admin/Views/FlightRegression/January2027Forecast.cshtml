
@model List<string>

@{
    ViewData["Title"] = "January2027Forecast";
    Layout = "~/Areas/Admin/Views/Layout/AdminLayout.cshtml";

    var parsedDates = new List<string>();
    var parsedMorning = new List<int>();
    var parsedEvening = new List<int>();

    foreach (var item in Model)
    {
        try
        {
            var parts = item.Split('→');
            var dateStr = parts[0].Trim();
            var halves = parts[1].Trim().Split('|');
            var mPax = int.Parse(System.Text.RegularExpressions.Regex.Match(halves[0], @"\d+").Value);
            var ePax = int.Parse(System.Text.RegularExpressions.Regex.Match(halves[1], @"\d+").Value);
            parsedDates.Add(dateStr);
            parsedMorning.Add(mPax);
            parsedEvening.Add(ePax);
        }
        catch
        {
            parsedDates.Add(item);
            parsedMorning.Add(0);
            parsedEvening.Add(0);
        }
    }

    int totalRows = parsedDates.Count;
    int morningCapacity = 180;
    int eveningCapacity = 180;
    int totalCapacity = morningCapacity + eveningCapacity; // 360
    double avgMorning = totalRows > 0 ? parsedMorning.Average() : 0;
    double avgEvening = totalRows > 0 ? parsedEvening.Average() : 0;
    // Load Factor = (Morning + Evening) / 360 * 100
    double avgLoad = totalRows > 0
        ? Enumerable.Range(0, totalRows)
            .Average(i => (parsedMorning[i] + parsedEvening[i]) / (double)totalCapacity * 100)
        : 0;

    // Peak Day — en yüksek toplam yolcuya sahip gün
    int peakIdx = 0;
    int peakMax = 0;
    for (int i = 0; i < totalRows; i++)
    {
        int total = parsedMorning[i] + parsedEvening[i];
        if (total > peakMax) { peakMax = total; peakIdx = i; }
    }
    string peakDay = totalRows > 0 ? parsedDates[peakIdx] : "—";
    int peakTotal = totalRows > 0 ? peakMax : 0;
}

@section Styles {
    <style>
        /* ── Genel sayfa zemini ── */
        .fc-page {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        /* ── Sayfa başlığı ── */
        .fc-page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }

        .fc-title {
            font-size: 22px;
            font-weight: 700;
            color: #0f172a;
            margin: 0 0 4px 0;
            letter-spacing: -.3px;
        }

        .fc-subtitle {
            font-size: 13px;
            color: #94a3b8;
            margin: 0;
        }

        .fc-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .fc-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 9px 18px;
            border-radius: 9px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all .15s;
            border: none;
            text-decoration: none;
        }

        .fc-btn-primary {
            background: #2563eb;
            color: #fff;
        }

            .fc-btn-primary:hover {
                background: #1d4ed8;
                box-shadow: 0 4px 14px rgba(37,99,235,.3);
                color: #fff;
            }

        .fc-btn-outline {
            background: #fff;
            color: #475569;
            border: 1.5px solid #e2e8f0;
        }

            .fc-btn-outline:hover {
                border-color: #94a3b8;
                color: #0f172a;
                background: #f8fafc;
            }

        /* ── KPI Cards ── */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
        }

        .kpi-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            padding: 20px 22px;
            box-shadow: 0 1px 4px rgba(15,23,42,.05);
            display: flex;
            flex-direction: column;
            gap: 12px;
            transition: box-shadow .15s;
        }

            .kpi-card:hover {
                box-shadow: 0 4px 18px rgba(15,23,42,.08);
            }

        .kpi-card-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .kpi-label {
            font-size: 11.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .7px;
            color: #94a3b8;
        }

        .kpi-ico {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            flex-shrink: 0;
        }

        .kpi-value {
            font-size: 28px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -.5px;
            line-height: 1;
        }

            .kpi-value span {
                font-size: 14px;
                font-weight: 500;
                color: #94a3b8;
                margin-left: 3px;
            }

        .kpi-footer {
            font-size: 12px;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .kpi-trend {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            font-size: 11.5px;
            font-weight: 600;
            padding: 2px 7px;
            border-radius: 5px;
        }

        .trend-up {
            background: #f0fdf4;
            color: #16a34a;
        }

        .trend-down {
            background: #fef2f2;
            color: #dc2626;
        }

        .trend-mid {
            background: #fffbeb;
            color: #d97706;
        }

        /* ── Filtre Barı ── */
        .fc-filter-bar {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 12px;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            box-shadow: 0 1px 3px rgba(15,23,42,.04);
        }

        .fc-filter-label {
            font-size: 12.5px;
            font-weight: 600;
            color: #475569;
            white-space: nowrap;
        }

        .fc-filter-chips {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .fc-chip {
            padding: 5px 13px;
            border-radius: 99px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid #e2e8f0;
            background: #f8fafc;
            color: #64748b;
            transition: all .13s;
            user-select: none;
        }

            .fc-chip.active, .fc-chip:hover {
                background: #eff6ff;
                border-color: #bfdbfe;
                color: #2563eb;
            }

        .fc-search {
            margin-left: auto;
            position: relative;
        }

            .fc-search i {
                position: absolute;
                left: 11px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 13px;
            }

            .fc-search input {
                padding: 7px 12px 7px 32px;
                border-radius: 8px;
                border: 1.5px solid #e2e8f0;
                font-size: 13px;
                color: #0f172a;
                background: #f8fafc;
                outline: none;
                width: 200px;
                transition: border-color .15s;
            }

                .fc-search input:focus {
                    border-color: #93c5fd;
                    background: #fff;
                }

        /* ── Ana tablo kartı ── */
        .fc-table-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(15,23,42,.05);
            overflow: hidden;
        }

        .fc-table-head {
            padding: 16px 22px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            background: #fafbfd;
        }

        .fc-table-title {
            font-size: 14px;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .fc-table-title i {
                color: #2563eb;
            }

        .fc-record-count {
            font-size: 12px;
            color: #94a3b8;
            font-weight: 500;
        }

        /* Tablo stilleri */
        .fc-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

            .fc-table thead tr {
                background: #f8fafc;
                border-bottom: 2px solid #f1f5f9;
            }

            .fc-table thead th {
                padding: 11px 16px;
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .6px;
                color: #94a3b8;
                text-align: left;
                white-space: nowrap;
            }

            .fc-table tbody tr {
                border-bottom: 1px solid #f8fafc;
                transition: background .13s;
            }

                .fc-table tbody tr:last-child {
                    border-bottom: none;
                }

                .fc-table tbody tr:hover {
                    background: #fafbfd;
                }

            .fc-table td {
                padding: 13px 16px;
                vertical-align: middle;
                color: #334155;
            }

        /* Tarih kolonu */
        .fc-date-cell {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .fc-date-main {
            font-weight: 700;
            color: #0f172a;
            font-size: 13.5px;
        }

        .fc-date-day {
            font-size: 11px;
            color: #94a3b8;
        }

        /* Pax badge */
        .pax-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 11px;
            border-radius: 99px;
            font-size: 12.5px;
            font-weight: 700;
            white-space: nowrap;
        }

        .pax-morning {
            background: #eff6ff;
            color: #2563eb;
            border: 1px solid #bfdbfe;
        }

        .pax-evening {
            background: #f5f3ff;
            color: #7c3aed;
            border: 1px solid #ddd6fe;
        }

        /* Load factor progress */
        .lf-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 140px;
        }

        .lf-bar-bg {
            flex: 1;
            height: 6px;
            background: #f1f5f9;
            border-radius: 99px;
            overflow: hidden;
        }

        .lf-bar-fill {
            height: 100%;
            border-radius: 99px;
            transition: width .4s ease;
        }

        .lf-pct {
            font-size: 12.5px;
            font-weight: 700;
            color: #0f172a;
            min-width: 36px;
            text-align: right;
        }

        /* Demand badge */
        .demand-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11.5px;
            font-weight: 700;
        }

        .demand-high {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        .demand-medium {
            background: #fffbeb;
            color: #d97706;
            border: 1px solid #fde68a;
        }

        .demand-low {
            background: #f0fdf4;
            color: #16a34a;
            border: 1px solid #bbf7d0;
        }

        /* Öneri kolonu */
        .op-tip {
            font-size: 12px;
            color: #64748b;
            display: flex;
            align-items: flex-start;
            gap: 6px;
            max-width: 220px;
            line-height: 1.5;
        }

            .op-tip i {
                color: #2563eb;
                flex-shrink: 0;
                margin-top: 1px;
                font-size: 11px;
            }

        /* ── Insights kartları ── */
        .insights-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
        }

        .insight-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 12px;
            padding: 16px 18px;
            display: flex;
            gap: 13px;
            align-items: flex-start;
            box-shadow: 0 1px 3px rgba(15,23,42,.04);
            transition: box-shadow .15s, transform .15s;
        }

            .insight-card:hover {
                box-shadow: 0 4px 16px rgba(15,23,42,.08);
                transform: translateY(-1px);
            }

        .insight-ico {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .insight-body {
        }

        .insight-title {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .insight-desc {
            font-size: 12px;
            color: #64748b;
            line-height: 1.55;
        }

        .insight-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin-top: 8px;
            padding: 2px 8px;
            border-radius: 5px;
            font-size: 11px;
            font-weight: 600;
        }

        /* ── Section başlığı ── */
        .fc-section-title {
            font-size: 15px;
            font-weight: 700;
            color: #0f172a;
            margin: 0 0 14px 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .fc-section-title i {
                color: #2563eb;
                font-size: 14px;
            }

        /* ── Responsive ── */
        @@media (max-width: 1100px) {
            .kpi-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .insights-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 700px) {
            .kpi-grid {
                grid-template-columns: 1fr;
            }

            .insights-grid {
                grid-template-columns: 1fr;
            }

            .fc-search input {
                width: 150px;
            }
        }
    </style>
}

<main class="main-content" id="main-content">
    <div class="container-fluid px-4 py-4">
        <div class="fc-page">

            @* ── Sayfa Başlığı ── *@
            <div class="fc-page-header">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1" style="font-size:12.5px;">
                            <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Dashboard</a></li>
                            <li class="breadcrumb-item active">Tahminler</li>
                        </ol>
                    </nav>
                    <h1 class="fc-title">2027 Ocak Uçuş Tahminleri</h1>
                    <p class="fc-subtitle">
                        <i class="bi bi-robot me-1"></i>
                        AI destekli yolcu yoğunluk tahminleri &bull; @totalRows günlük veri
                    </p>
                </div>
                <div class="fc-actions">
                    <button class="fc-btn fc-btn-outline" onclick="exportCSV()">
                        <i class="bi bi-download"></i> Csv'ye Aktar
                    </button>
                    <button class="fc-btn fc-btn-primary" onclick="showAIReport()">
                        <i class="bi bi-stars"></i> AI Tahmin Raporu
                    </button>
                </div>
            </div>

            @* ── KPI Cards ── *@
            <div class="kpi-grid">

                <div class="kpi-card">
                    <div class="kpi-card-top">
                        <div class="kpi-label">Ort. Sabah Yolcusu</div>
                        <div class="kpi-ico" style="background:#eff6ff;color:#2563eb;">
                            <i class="bi bi-sunrise-fill"></i>
                        </div>
                    </div>
                    <div class="kpi-value">
                        @Math.Round(avgMorning, 0)<span>yolcu</span>
                    </div>
                    <div class="kpi-footer">
                        <span class="kpi-trend trend-up"><i class="bi bi-arrow-up"></i> +4.2%</span>
                        geçen aya göre
                    </div>
                </div>

                <div class="kpi-card">
                    <div class="kpi-card-top">
                        <div class="kpi-label">Ort. Akşam Yolcusu</div>
                        <div class="kpi-ico" style="background:#f5f3ff;color:#7c3aed;">
                            <i class="bi bi-moon-stars-fill"></i>
                        </div>
                    </div>
                    <div class="kpi-value">
                        @Math.Round(avgEvening, 0)<span>yolcu</span>
                    </div>
                    <div class="kpi-footer">
                        <span class="kpi-trend trend-up"><i class="bi bi-arrow-up"></i> +6.8%</span>
                        geçen aya göre
                    </div>
                </div>

                <div class="kpi-card">
                    <div class="kpi-card-top">
                        <div class="kpi-label">Ort. Doluluk Oranı</div>
                        <div class="kpi-ico" style="background:#f0fdf4;color:#16a34a;">
                            <i class="bi bi-speedometer2"></i>
                        </div>
                    </div>
                    <div class="kpi-value">
                        @Math.Round(avgLoad, 1)<span>%</span>
                    </div>
                    <div class="kpi-footer">
                        <span class="kpi-trend @(avgLoad >= 85 ? "trend-down" : avgLoad >= 70 ? "trend-mid" : "trend-up")">
                            @(avgLoad >= 85 ? "Yüksek" : avgLoad >= 70 ? "Orta" : "Düşük")
                        </span>
                        kapasite doluluk oranı
                    </div>
                </div>

                <div class="kpi-card">
                    <div class="kpi-card-top">
                        <div class="kpi-label">En Yoğun Gün</div>
                        <div class="kpi-ico" style="background:#fff1f2;color:#e11d48;">
                            <i class="bi bi-graph-up-arrow"></i>
                        </div>
                    </div>
                    <div class="kpi-value" style="font-size:20px;">
                        @peakDay
                    </div>
                    <div class="kpi-footer">
                        <span class="kpi-trend trend-down"><i class="bi bi-exclamation-triangle"></i> Peak</span>
                        @peakTotal toplam yolcu
                    </div>
                </div>

            </div>

            @* ── Filtre Barı ── *@
            <div class="fc-filter-bar">
                <span class="fc-filter-label"><i class="bi bi-funnel me-1"></i> Filtrele:</span>
                <div class="fc-filter-chips">
                    <span class="fc-chip active" onclick="filterTable('all', this)">Tümü</span>
                    <span class="fc-chip" onclick="filterTable('high', this)">
                        <i class="bi bi-circle-fill" style="font-size:7px;color:#dc2626;"></i> Yüksek Talep
                    </span>
                    <span class="fc-chip" onclick="filterTable('medium', this)">
                        <i class="bi bi-circle-fill" style="font-size:7px;color:#d97706;"></i> Orta Talep
                    </span>
                    <span class="fc-chip" onclick="filterTable('low', this)">
                        <i class="bi bi-circle-fill" style="font-size:7px;color:#16a34a;"></i> Düşük Talep
                    </span>
                    <span class="fc-chip" onclick="filterTable('weekend', this)">
                        <i class="bi bi-calendar-weekend"></i> Hafta Sonu
                    </span>
                </div>
                <div class="fc-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Tarih ara..." id="fcSearchInput" oninput="searchTable(this.value)" />
                </div>
            </div>

            @* ── Veri Tablosu ── *@
            <div class="fc-table-card">
                <div class="fc-table-head">
                    <div class="fc-table-title">
                        <i class="bi bi-table"></i>
                        Günlük Tahmin Detayları
                    </div>
                    <span class="fc-record-count" id="recordCount">@totalRows kayıt</span>
                </div>
                <div style="overflow-x:auto;">
                    <table class="fc-table" id="forecastTable">
                        <thead>
                            <tr>
                                <th>Tarih</th>
                                <th>Gündüz Uçuşu</th>
                                <th>Akşam Uçuşu</th>
                                <th style="min-width:160px;">Doluluk Oranı</th>
                                <th>Talep</th>
                                <th>Operasyon Önerisi</th>
                                <th style="text-align:center;">Kaynak</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                @* Parse işlemi her satır için tekrar *@
                                string rawDate = "—";
                                int mPax = 0;
                                int ePax = 0;
                                string dayName = "";

                                try
                                {
                                    var p = item.Split('→');
                                    rawDate = p[0].Trim();
                                    var h = p[1].Trim().Split('|');
                                    mPax = int.Parse(System.Text.RegularExpressions.Regex.Match(h[0], @"\d+").Value);
                                    ePax = int.Parse(System.Text.RegularExpressions.Regex.Match(h[1], @"\d+").Value);
                                    // Gün adı
                                    if (DateTime.TryParseExact(rawDate, "dd.MM.yyyy",
                                    System.Globalization.CultureInfo.InvariantCulture,
                                    System.Globalization.DateTimeStyles.None, out DateTime dt))
                                    {
                                        dayName = dt.ToString("dddd", new System.Globalization.CultureInfo("tr-TR"));
                                    }
                                }
                                catch { }

                                double lf = (mPax + ePax) / 360.0 * 100;
                                string lfColor = lf >= 85 ? "#dc2626" : lf >= 70 ? "#d97706" : "#16a34a";
                                string lfBg = lf >= 85 ? "#fef2f2" : lf >= 70 ? "#fffbeb" : "#f0fdf4";

                                string demandLvl = lf >= 85 ? "high" : lf >= 70 ? "medium" : "low";
                                string demandLabel = lf >= 85 ? "Yüksek" : lf >= 70 ? "Orta" : "Düşük";
                                string demandClass = lf >= 85 ? "demand-high" : lf >= 70 ? "demand-medium" : "demand-low";
                                string demandIcon = lf >= 85 ? "bi-fire" : lf >= 70 ? "bi-dash-circle" : "bi-check-circle";

                                bool isWeekend = dayName == "cumartesi" || dayName == "pazar";

                                string tip = lf >= 85
                                ? "Ekstra personel ve uçak hazırlığı önerilir."
                                : lf >= 70
                                ? "Standart operasyon. Anlık takip yapılmalı."
                                : "Düşük doluluk. İndirim kampanyası değerlendirilebilir.";

                                <tr data-demand="@demandLvl" data-weekend="@(isWeekend ? "true" : "false")" data-date="@rawDate" class="fc-row">
                                    <td>
                                        <div class="fc-date-cell">
                                            <span class="fc-date-main">@rawDate</span>
                                            <span class="fc-date-day">
                                                @dayName
                                                @if (isWeekend)
                                                {
                                                    <span class="badge rounded-pill ms-1"
                                                          style="font-size:9px;background:#f5f3ff;color:#7c3aed;padding:2px 6px;">WE</span>
                                                }
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="pax-badge pax-morning">
                                            <i class="bi bi-sunrise" style="font-size:10px;"></i>
                                            @mPax yolcu
                                        </span>
                                    </td>
                                    <td>
                                        <span class="pax-badge pax-evening">
                                            <i class="bi bi-moon-stars" style="font-size:10px;"></i>
                                            @ePax yolcu
                                        </span>
                                    </td>
                                    <td>
