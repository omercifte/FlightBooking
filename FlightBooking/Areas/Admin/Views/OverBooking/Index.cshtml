            @* ═══════ 7 — AI OPERATIONAL INSIGHTS ═══════ *@
            @if (Model.AiInsights != null && Model.AiInsights.Any())
            {
                <div>
                    <h3 class="ob-sec-title">
                        <i class="bi bi-lightbulb-fill"></i> AI Operational Insights
                        <span class="ob-sec-sub">@Model.AiInsights.Count öneri üretildi</span>
                    </h3>
                    <div class="ins-grid">
                        @{
                            var styles = new[] {
                    ("bi-exclamation-triangle-fill","#fef2f2","#dc2626","#fef2f2","#dc2626","Kritik"),
                    ("bi-airplane-fill",            "#eff6ff","#2563eb","#eff6ff","#2563eb","Öneri"),
                    ("bi-graph-up-arrow",           "#fffbeb","#d97706","#fffbeb","#d97706","Strateji"),
                    ("bi-shield-check-fill",        "#f0fdf4","#16a34a","#f0fdf4","#16a34a","Pozitif"),
                    ("bi-people-fill",              "#f5f3ff","#7c3aed","#f5f3ff","#7c3aed","Planlama"),
                    ("bi-currency-dollar",          "#ecfdf5","#059669","#f0fdf4","#16a34a","Fırsat"),
                    ("bi-calendar-week",            "#fffbeb","#d97706","#fffbeb","#d97706","Hafta Sonu"),
                    ("bi-lightning-charge-fill",    "#fef2f2","#dc2626","#fef2f2","#dc2626","Acil"),
                    };
                            int idx = 0;
                        }
                        @foreach (var insight in Model.AiInsights)
                        {
                            var s = styles[idx % styles.Length];
                            idx++;
                            <div class="ins-card">
                                <div class="ins-ico" style="background:@s.Item2;color:@s.Item3;"><i class="bi @s.Item1"></i></div>
                                <div>
                                    <div class="ins-title">AI Öneri #@idx</div>
                                    <div class="ins-desc">@insight</div>
                                    <span class="ins-tag" style="background:@s.Item4;color:@s.Item5;">
                                        <i class="bi bi-stars"></i> @s.Item6
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @* ═══════ 8 — OPERATIONAL PRESSURE WIDGETS ═══════ *@
            <div>
                <h3 class="ob-sec-title">
                    <i class="bi bi-speedometer2"></i> Operasyonel Baskı Göstergeleri
                    <span class="ob-sec-sub">Model'den türetilen anlık durum</span>
                </h3>
                @{
                    double gatePressure = Math.Min(Model.AverageNoShowRate * 10, 100);
                    double boardingRisk = Model.Recommendations != null && Model.Recommendations.Any()
                    ? Math.Min(Model.Recommendations.Average(r => r.ExpectedNoShowRate) * 12, 100) : 50;
                    double crewLoad = Math.Min(Model.SuggestedOverbookingRate * 8, 100);
                    double standbyReq = Math.Min(Model.AverageNoShowRate * 9, 100);
                    double weekendVolat = 72.0;
                    string PressureColor(double v) => v >= 70 ? "#dc2626" : v >= 50 ? "#d97706" : "#16a34a";
                }
                <div class="pressure-grid">
                    <div class="pressure-card">
                        <div class="pc-top"><span class="pc-lbl">Gate Pressure</span><div class="pc-ico" style="background:#eff6ff;color:#2563eb;"><i class="bi bi-door-open-fill"></i></div></div>
                        <div class="pc-val" style="color:@PressureColor(gatePressure);">%@gatePressure.ToString("0")</div>
                        <div class="pc-bar-bg"><div class="pc-bar-fill" style="width:@gatePressure.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%;background:@PressureColor(gatePressure);"></div></div>
                        <div class="pc-foot"><i class="bi bi-info-circle"></i> No-show'a bağlı gate baskısı</div>
                    </div>
                    <div class="pressure-card">
                        <div class="pc-top"><span class="pc-lbl">Boarding Risk</span><div class="pc-ico" style="background:#fff7ed;color:#ea580c;"><i class="bi bi-person-exclamation"></i></div></div>
                        <div class="pc-val" style="color:@PressureColor(boardingRisk);">%@boardingRisk.ToString("0")</div>
                        <div class="pc-bar-bg"><div class="pc-bar-fill" style="width:@boardingRisk.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%;background:@PressureColor(boardingRisk);"></div></div>
                        <div class="pc-foot"><i class="bi bi-info-circle"></i> Biniş riski endeksi</div>
                    </div>
                    <div class="pressure-card">
                        <div class="pc-top"><span class="pc-lbl">Crew Load</span><div class="pc-ico" style="background:#f5f3ff;color:#7c3aed;"><i class="bi bi-people-fill"></i></div></div>
                        <div class="pc-val" style="color:@PressureColor(crewLoad);">%@crewLoad.ToString("0")</div>
                        <div class="pc-bar-bg"><div class="pc-bar-fill" style="width:@crewLoad.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%;background:@PressureColor(crewLoad);"></div></div>
                        <div class="pc-foot"><i class="bi bi-info-circle"></i> Ekip yoğunluğu</div>
                    </div>
                    <div class="pressure-card">
                        <div class="pc-top"><span class="pc-lbl">Standby İhtiyacı</span><div class="pc-ico" style="background:#fef2f2;color:#dc2626;"><i class="bi bi-person-plus-fill"></i></div></div>
                        <div class="pc-val" style="color:@PressureColor(standbyReq);">%@standbyReq.ToString("0")</div>
                        <div class="pc-bar-bg"><div class="pc-bar-fill" style="width:@standbyReq.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%;background:@PressureColor(standbyReq);"></div></div>
                        <div class="pc-foot"><i class="bi bi-info-circle"></i> Yedek personel ihtiyacı</div>
                    </div>
                    <div class="pressure-card">
                        <div class="pc-top"><span class="pc-lbl">Weekend Volatility</span><div class="pc-ico" style="background:#fffbeb;color:#d97706;"><i class="bi bi-calendar-week"></i></div></div>
                        <div class="pc-val" style="color:#d97706;">%@weekendVolat.ToString("0")</div>
                        <div class="pc-bar-bg"><div class="pc-bar-fill" style="width:@weekendVolat.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%;background:#d97706;"></div></div>
                        <div class="pc-foot"><i class="bi bi-info-circle"></i> Hafta sonu dalgalanması</div>
                    </div>
                </div>
            </div>

            @* ═══════ 9 — AI RISK TIMELINE ═══════ *@
            <div class="timeline-card">
                <div class="timeline-head">
                    <div class="timeline-title"><i class="bi bi-calendar3"></i> AI Risk Timeline — Ocak 2026</div>
                    <span style="font-size:12px;color:#94a3b8;">Recommendations'dan türetilen günlük risk dağılımı</span>
                </div>
                <div class="timeline-body">
                    @{
                        var dateRiskMap = new Dictionary<int, string>();
                        if (Model.Recommendations != null)
                        {
                            foreach (var rec in Model.Recommendations)
                            {
                                if (DateTime.TryParse(rec.FlightDate, out DateTime rd) && rd.Month == 1)
                                {
                                    int day = rd.Day;
                                    if (!dateRiskMap.ContainsKey(day))
                                        dateRiskMap[day] = rec.RiskLevel;
                                    else
                                    {
                                        var pri = new[] { "Critical", "High", "Medium", "Low" };
                                        if (Array.IndexOf(pri, rec.RiskLevel) < Array.IndexOf(pri, dateRiskMap[day]))
                                            dateRiskMap[day] = rec.RiskLevel;
                                    }
                                }
                            }
                        }
                        var defRisks = new[] {
                    "Low","Low","Medium","Medium","High","High","Critical",
                    "Low","Low","Medium","High","High","Critical","Low",
                    "Medium","Medium","High","Low","Low","Medium",
                    "High","Critical","Low","Low","Medium","High","High","Low","Medium","Critical","Low"
                    };
                        string TlClass(string r) => r == "Critical" ? "tl-critical" : r == "High" ? "tl-high" : r == "Medium" ? "tl-medium" : "tl-low";
                    }
                    <div class="timeline-grid">
                        @for (int d = 1; d <= 31; d++)
                        {
                            string risk = dateRiskMap.ContainsKey(d) ? dateRiskMap[d] : defRisks[d - 1];
                            string tlCls = TlClass(risk);
                            <div class="tl-day @tlCls" title="@d Ocak — @riskLabel(risk)">
                                <span class="tl-day-num">@d</span>
                                <span class="tl-day-dot"></span>
                            </div>
                        }
                    </div>
                    <div class="tl-legend">
                        <div class="tll-item"><div class="tll-box" style="background:#f0fdf4;border:1px solid #bbf7d0;"></div> Düşük Trafik</div>
                        <div class="tll-item"><div class="tll-box" style="background:#fffbeb;border:1px solid #fde68a;"></div> Orta Yoğunluk</div>
                        <div class="tll-item"><div class="tll-box" style="background:#fff7ed;border:1px solid #fed7aa;"></div> Yüksek Talep</div>
                        <div class="tll-item"><div class="tll-box" style="background:#fef2f2;border:1px solid #fecaca;"></div> Kritik Gün</div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</main>

@section Scripts {
    <script>
        function obFilter(risk, btn) {
            document.querySelectorAll('.ob-chip').forEach(function(c){ c.classList.remove('active'); });
            btn.classList.add('active');
            var rows = document.querySelectorAll('#obTable tbody .ob-row');
            var vis  = 0;
            rows.forEach(function(row) {
                var show = risk === 'all' || row.dataset.risk === risk;
                row.style.display = show ? '' : 'none';
                if (show) vis++;
            });
            document.getElementById('obRecCount').textContent = vis + ' kayıt';
        }

        function obSearch(val) {
            var rows = document.querySelectorAll('#obTable tbody .ob-row');
            var vis  = 0;
            val = val.toLowerCase();
            rows.forEach(function(row) {
                var show = val === '' || (row.dataset.search || '').toLowerCase().includes(val);
                row.style.display = show ? '' : 'none';
                if (show) vis++;
            });
            document.getElementById('obRecCount').textContent = vis + ' kayıt';
        }

        function exportCSV() {
            var rows  = document.querySelectorAll('#obTable tbody .ob-row');
            var lines = ['Tarih,Slot,Gerçek Pax,Tahmin Pax,Kapasite,Bek. No-Show,Önerilen Satış,Ekstra Koltuk,Risk'];
            rows.forEach(function(row) {
                if (row.style.display === 'none') return;
                var tds = row.querySelectorAll('td');
                var arr = [];
                for (var i = 0; i < 9; i++) arr.push(tds[i] ? tds[i].textContent.trim().replace(/\s+/g,' ') : '');
                lines.push(arr.join(','));
            });
            var blob = new Blob([lines.join('\n')], { type:'text/csv;charset=utf-8;' });
            var url  = URL.createObjectURL(blob);
            var a    = document.createElement('a');
            a.href = url; a.download = 'overbooking-rapor.csv'; a.click();
            URL.revokeObjectURL(url);
        }
    </script>
}
