                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:55%;background:#d97706;"></div></div>
                            </div>
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">No-Show Eğilimi</span><span class="ac-metric-val" style="color:#2563eb;">%5.2</span></div>
                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:52%;background:#2563eb;"></div></div>
                            </div>
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">Overbooking Uygunluğu</span><span class="ac-metric-val" style="color:#16a34a;">Yüksek</span></div>
                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:75%;background:#16a34a;"></div></div>
                            </div>
                        </div>
                        <div class="ac-tags">
                            <span class="ac-tag" style="background:#eff6ff;color:#2563eb;">Short-haul</span>
                            <span class="ac-tag" style="background:#f0fdf4;color:#16a34a;">Uygun</span>
                        </div>
                    </div>

                    <div class="aircraft-card">
                        <div class="ac-header">
                            <div class="ac-ico" style="background:#f5f3ff;color:#7c3aed;"><i class="bi bi-airplane-fill"></i></div>
                            <div><div class="ac-name">Airbus A321</div><div class="ac-type">220 koltuk · Narrow-body</div></div>
                        </div>
                        <div class="ac-metrics">
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">Operasyon Riski</span><span class="ac-metric-val" style="color:#16a34a;">Düşük</span></div>
                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:35%;background:#16a34a;"></div></div>
                            </div>
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">No-Show Eğilimi</span><span class="ac-metric-val" style="color:#2563eb;">%4.8</span></div>
                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:48%;background:#2563eb;"></div></div>
                            </div>
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">Overbooking Uygunluğu</span><span class="ac-metric-val" style="color:#16a34a;">Çok Yüksek</span></div>
                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:88%;background:#16a34a;"></div></div>
                            </div>
                        </div>
                        <div class="ac-tags">
                            <span class="ac-tag" style="background:#f5f3ff;color:#7c3aed;">Geniş Kapasite</span>
                            <span class="ac-tag" style="background:#f0fdf4;color:#16a34a;">Tercih Edilen</span>
                        </div>
                    </div>

                    <div class="aircraft-card">
                        <div class="ac-header">
                            <div class="ac-ico" style="background:#fff7ed;color:#ea580c;"><i class="bi bi-airplane-fill"></i></div>
                            <div><div class="ac-name">Boeing 737 MAX</div><div class="ac-type">189 koltuk · Narrow-body</div></div>
                        </div>
                        <div class="ac-metrics">
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">Operasyon Riski</span><span class="ac-metric-val" style="color:#dc2626;">Yüksek</span></div>
                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:72%;background:#dc2626;"></div></div>
                            </div>
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">No-Show Eğilimi</span><span class="ac-metric-val" style="color:#2563eb;">%6.9</span></div>
                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:69%;background:#2563eb;"></div></div>
                            </div>
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">Overbooking Uygunluğu</span><span class="ac-metric-val" style="color:#d97706;">Orta</span></div>
                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:50%;background:#d97706;"></div></div>
                            </div>
