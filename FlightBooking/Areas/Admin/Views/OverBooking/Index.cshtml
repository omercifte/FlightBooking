                            <span class="ac-tag" style="background:#fef2f2;color:#dc2626;">Yüksek Risk</span>
                        </div>
                    </div>

                    <div class="aircraft-card">
                        <div class="ac-header">
                            <div class="ac-ico" style="background:#f0fdf4;color:#16a34a;"><i class="bi bi-airplane-fill"></i></div>
                            <div><div class="ac-name">A321neo HD</div><div class="ac-type">240 koltuk · High Density</div></div>
                        </div>
                        <div class="ac-metrics">
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">Operasyon Riski</span><span class="ac-metric-val" style="color:#16a34a;">Çok Düşük</span></div>
                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:22%;background:#16a34a;"></div></div>
                            </div>
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">No-Show Eğilimi</span><span class="ac-metric-val" style="color:#2563eb;">%3.9</span></div>
                                <div class="ac-bar-bg"><div class="ac-bar-fill" style="width:39%;background:#2563eb;"></div></div>
                            </div>
                            <div class="ac-metric">
                                <div class="ac-metric-header"><span class="ac-metric-lbl">Overbooking Uygunluğu</span><span class="ac-metric-val" style="color:#16a34a;">Maksimum</span></div>
