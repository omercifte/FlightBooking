@using FlightBooking.Dtos.NoShowDtos

@model OverbookingDashboardDto

@{
    ViewData["Title"] = "Overbooking Control Center";
    Layout = "~/Areas/Admin/Views/Layout/AdminLayout.cshtml";

    Func<string, string> riskColor = (r) => r == "Critical" ? "#dc2626" : r == "High" ? "#ea580c" : r == "Medium" ? "#d97706" : "#16a34a";
    Func<string, string> riskBg = (r) => r == "Critical" ? "#fef2f2" : r == "High" ? "#fff7ed" : r == "Medium" ? "#fffbeb" : "#f0fdf4";
    Func<string, string> riskBorder = (r) => r == "Critical" ? "#fecaca" : r == "High" ? "#fed7aa" : r == "Medium" ? "#fde68a" : "#bbf7d0";
    Func<string, string> riskLabel = (r) => r == "Critical" ? "Kritik" : r == "High" ? "Yüksek" : r == "Medium" ? "Orta" : "Düşük";
    Func<string, string> riskIcon = (r) => r == "Critical" ? "bi-fire" : r == "High" ? "bi-exclamation-triangle-fill" : r == "Medium" ? "bi-dash-circle" : "bi-check-circle";
}

@section Styles {
    <style>
        .ob-page {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        /* ─── HEADER ─── */
        .ob-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }

        .ob-title {
            font-size: 22px;
            font-weight: 700;
            color: #0f172a;
            margin: 0 0 4px;
            letter-spacing: -.3px;
        }

        .ob-sub {
            font-size: 13px;
            color: #94a3b8;
            margin: 0;
        }

        .ob-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .ob-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 9px 18px;
            border-radius: 9px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all .15s;
            border: none;
            text-decoration: none;
        }

        .ob-btn-primary {
            background: #2563eb;
            color: #fff;
        }

            .ob-btn-primary:hover {
                background: #1d4ed8;
                box-shadow: 0 4px 14px rgba(37,99,235,.28);
                color: #fff;
            }

        .ob-btn-outline {
            background: #fff;
            color: #475569;
            border: 1.5px solid #e2e8f0;
        }

            .ob-btn-outline:hover {
                border-color: #94a3b8;
                color: #0f172a;
            }

        /* ─── FLIGHT OPERATION SUMMARY ─── */
        .fos-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            padding: 22px 26px;
            box-shadow: 0 1px 4px rgba(15,23,42,.05);
            position: relative;
            overflow: hidden;
        }

            .fos-card::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0;
                bottom: 0;
                width: 3px;
                background: linear-gradient(180deg,#2563eb,#7c3aed);
                border-radius: 14px 0 0 14px;
            }

        .fos-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }

        .fos-route-wrap {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .fos-airport {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .fos-airport-right {
            text-align: right;
        }

        .fos-iata {
            font-size: 28px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -.5px;
            line-height: 1;
        }

        .fos-apt-name {
            font-size: 11.5px;
            font-weight: 600;
            color: #475569;
        }

        .fos-apt-country {
            font-size: 10.5px;
            color: #94a3b8;
        }

        .fos-connector {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            min-width: 180px;
        }

        .fos-conn-line {
            display: flex;
            align-items: center;
            gap: 4px;
            width: 100%;
        }

        .fos-conn-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #2563eb;
            flex-shrink: 0;
        }

        .fos-conn-dash {
            flex: 1;
            height: 1.5px;
            background: repeating-linear-gradient(90deg,#bfdbfe 0,#bfdbfe 5px,transparent 5px,transparent 9px);
        }

        .fos-plane-ico {
            font-size: 17px;
            color: #2563eb;
            flex-shrink: 0;
        }

        .fos-conn-meta {
            display: flex;
            gap: 14px;
            font-size: 10.5px;
            color: #94a3b8;
            font-weight: 600;
        }

        .fos-badges {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .fos-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 12px;
            border-radius: 99px;
            font-size: 11.5px;
            font-weight: 600;
            border: 1.5px solid transparent;
        }

        .fb-blue {
            background: #eff6ff;
            color: #2563eb;
            border-color: #bfdbfe;
        }

        .fb-green {
            background: #f0fdf4;
            color: #16a34a;
            border-color: #bbf7d0;
        }

        .fb-purple {
            background: #f5f3ff;
            color: #7c3aed;
            border-color: #ddd6fe;
        }

        .fb-orange {
            background: #fff7ed;
            color: #ea580c;
            border-color: #fed7aa;
        }

        .fos-divider {
            border: none;
            border-top: 1px dashed #e2e8f0;
            margin: 18px 0;
        }

        .fos-meta-grid {
            display: flex;
            align-items: flex-start;
            flex-wrap: wrap;
        }

        .fos-meta-item {
            display: flex;
            align-items: flex-start;
            gap: 11px;
            padding: 0 20px;
            flex: 1;
            min-width: 150px;
        }

            .fos-meta-item:first-child {
                padding-left: 0;
            }

        .fos-meta-sep {
            width: 1px;
            background: #f1f5f9;
            align-self: stretch;
            min-height: 52px;
        }

        .fos-meta-ico {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            flex-shrink: 0;
        }

        .fos-meta-body {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .fos-meta-lbl {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .7px;
            color: #94a3b8;
        }

        .fos-meta-val {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
        }

        .fos-meta-sub {
            font-size: 11px;
            color: #94a3b8;
        }

        .fos-chips {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
            margin-top: 3px;
        }

        .fos-chip {
            padding: 2px 8px;
            border-radius: 5px;
            font-size: 10.5px;
            font-weight: 700;
        }

        .fc-morning {
            background: #eff6ff;
            color: #2563eb;
        }

        .fc-evening {
            background: #f5f3ff;
            color: #7c3aed;
        }

        .fc-ai {
            background: #fff7ed;
            color: #ea580c;
            border: 1px solid #fed7aa;
        }

        .fos-fleet {
            display: flex;
            flex-wrap: wrap;
            gap: 2px 8px;
            margin-top: 3px;
        }

        .fos-fleet-item {
            font-size: 11px;
            color: #475569;
            font-weight: 500;
            display: flex;
            align-items: center;
        }

            .fos-fleet-item i {
                color: #dc2626;
                font-size: 15px;
            }

        /* ─── KPI CARDS ─── */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(6,1fr);
            gap: 14px;
        }

        .kpi-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            padding: 18px;
            box-shadow: 0 1px 4px rgba(15,23,42,.05);
            display: flex;
            flex-direction: column;
            gap: 12px;
            transition: box-shadow .18s,transform .18s;
            position: relative;
            overflow: hidden;
        }

            .kpi-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                border-radius: 14px 14px 0 0;
            }

            .kpi-card:hover {
                box-shadow: 0 6px 22px rgba(15,23,42,.09);
                transform: translateY(-2px);
            }

        .kc-blue::before {
            background: linear-gradient(90deg,#2563eb,#60a5fa);
        }

        .kc-red::before {
            background: linear-gradient(90deg,#dc2626,#f87171);
        }

        .kc-green::before {
            background: linear-gradient(90deg,#16a34a,#4ade80);
        }

        .kc-orange::before {
            background: linear-gradient(90deg,#d97706,#fbbf24);
        }

        .kc-purple::before {
            background: linear-gradient(90deg,#7c3aed,#a78bfa);
        }

        .kc-teal::before {
            background: linear-gradient(90deg,#0891b2,#22d3ee);
        }

        .kpi-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .kpi-lbl {
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .7px;
            color: #94a3b8;
        }

        .kpi-ico {
            width: 32px;
            height: 32px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

        .kpi-val {
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -.5px;
            line-height: 1;
        }

        .kpi-val-sm {
            font-size: 17px;
            font-weight: 800;
            color: #0f172a;
            line-height: 1.2;
            margin-top: 2px;
        }

        .kpi-foot {
            font-size: 11.5px;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .kpi-bdg {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            font-size: 11px;
            font-weight: 600;
            padding: 2px 7px;
            border-radius: 5px;
        }

        .kb-red {
            background: #fef2f2;
            color: #dc2626;
        }

        .kb-green {
            background: #f0fdf4;
            color: #16a34a;
        }

        .kb-orange {
            background: #fffbeb;
            color: #d97706;
        }

        .kb-blue {
            background: #eff6ff;
            color: #2563eb;
        }

        .kb-purple {
            background: #f5f3ff;
            color: #7c3aed;
        }

        .kb-teal {
            background: #ecfeff;
            color: #0891b2;
        }

        /* ─── HEATMAP ─── */
        .heatmap-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(15,23,42,.05);
            overflow: hidden;
        }

        .heatmap-head {
            padding: 14px 20px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fafbfd;
            flex-wrap: wrap;
            gap: 10px;
        }

        .heatmap-title {
            font-size: 14px;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .heatmap-title i {
                color: #2563eb;
            }

        .heatmap-legend {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .hml-item {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 11.5px;
            color: #64748b;
        }

        .hml-dot {
            width: 10px;
            height: 10px;
            border-radius: 3px;
            flex-shrink: 0;
        }

        .heatmap-body {
            padding: 16px 20px;
        }

        .heatmap-grid {
            display: grid;
            grid-template-columns: 90px repeat(4,1fr);
            gap: 6px;
        }

        .hm-col-header {
            text-align: center;
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: .5px;
            padding: 4px;
        }

        .hm-row-label {
            display: flex;
            align-items: center;
            font-size: 11.5px;
            font-weight: 600;
            color: #475569;
        }

        .hm-cell {
            border-radius: 8px;
            padding: 10px 6px;
            text-align: center;
            cursor: default;
            transition: transform .13s,box-shadow .13s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
        }

            .hm-cell:hover {
                transform: scale(1.05);
                box-shadow: 0 3px 10px rgba(0,0,0,.1);
            }

        .hm-cell-val {
            font-size: 13px;
            font-weight: 800;
        }

        .hm-cell-lbl {
            font-size: 9px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .4px;
            opacity: .8;
        }

        /* ─── ANA TABLO ─── */
        .ob-table-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(15,23,42,.05);
            overflow: hidden;
        }

        .ob-table-head {
            padding: 14px 20px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            background: #fafbfd;
        }

        .ob-table-title {
            font-size: 14px;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .ob-table-title i {
                color: #2563eb;
            }

        .ob-rec-count {
            font-size: 12px;
            color: #94a3b8;
        }

        .ob-filter-bar {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            padding: 12px 20px;
            border-bottom: 1px solid #f1f5f9;
            background: #fafbfd;
        }

        .ob-chip {
            padding: 4px 12px;
            border-radius: 99px;
            font-size: 11.5px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid #e2e8f0;
            background: #fff;
            color: #64748b;
            transition: all .13s;
        }

            .ob-chip.active, .ob-chip:hover {
                background: #eff6ff;
                border-color: #bfdbfe;
                color: #2563eb;
            }

        .ob-search {
            margin-left: auto;
            position: relative;
        }

            .ob-search i {
                position: absolute;
                left: 10px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 12px;
            }

            .ob-search input {
                padding: 6px 10px 6px 30px;
                border-radius: 8px;
                border: 1.5px solid #e2e8f0;
                font-size: 12.5px;
                color: #0f172a;
                background: #fff;
                outline: none;
                width: 180px;
            }

                .ob-search input:focus {
                    border-color: #93c5fd;
                }

        .ob-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12.5px;
        }

            .ob-table thead tr {
                background: #f8fafc;
                border-bottom: 2px solid #f1f5f9;
            }

            .ob-table thead th {
                padding: 10px 14px;
                font-size: 10.5px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .6px;
                color: #94a3b8;
                text-align: left;
                white-space: nowrap;
            }

            .ob-table tbody tr {
                border-bottom: 1px solid #f8fafc;
                transition: background .13s;
            }

                .ob-table tbody tr:last-child {
                    border-bottom: none;
                }

                .ob-table tbody tr:hover {
                    background: #fafbfd;
                }

            .ob-table td {
                padding: 12px 14px;
                vertical-align: middle;
                color: #334155;
            }

        .ob-date-cell {
            display: flex;
            flex-direction: column;
            gap: 1px;
        }

        .ob-date-main {
            font-weight: 700;
            color: #0f172a;
            font-size: 13px;
        }

        .ob-date-day {
            font-size: 10.5px;
            color: #94a3b8;
        }

        .slot-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            border-radius: 99px;
            font-size: 11.5px;
            font-weight: 700;
        }

        .sp-morning {
            background: #eff6ff;
            color: #2563eb;
            border: 1px solid #bfdbfe;
        }

        .sp-evening {
            background: #f5f3ff;
            color: #7c3aed;
            border: 1px solid #ddd6fe;
        }

        .ob-num {
            font-weight: 700;
            color: #0f172a;
        }

        .cap-bar-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
            min-width: 100px;
        }

        .cap-bar-bg {
            flex: 1;
            height: 5px;
            background: #f1f5f9;
            border-radius: 99px;
            overflow: hidden;
        }

        .cap-bar-fill {
            height: 100%;
            border-radius: 99px;
        }

        .noshow-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 9px;
            border-radius: 6px;
            font-size: 11.5px;
            font-weight: 700;
        }

        .rec-sale-pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 99px;
            font-size: 11.5px;
            font-weight: 700;
            background: #f0fdf4;
            color: #16a34a;
            border: 1px solid #bbf7d0;
        }

        .extra-seat-pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 99px;
            font-size: 11.5px;
            font-weight: 700;
            background: #eff6ff;
            color: #2563eb;
            border: 1px solid #bfdbfe;
        }

        .risk-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11.5px;
            font-weight: 700;
        }

        .ai-rec {
            font-size: 11.5px;
            color: #64748b;
            display: flex;
            align-items: flex-start;
            gap: 5px;
            max-width: 200px;
            line-height: 1.45;
        }

            .ai-rec i {
                color: #2563eb;
                flex-shrink: 0;
                margin-top: 1px;
                font-size: 10px;
            }

        /* ─── AIRCRAFT ─── */
        .aircraft-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
        }

        .aircraft-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 12px;
            padding: 16px 18px;
            box-shadow: 0 1px 3px rgba(15,23,42,.04);
            transition: box-shadow .15s,transform .15s;
        }

            .aircraft-card:hover {
                box-shadow: 0 4px 16px rgba(15,23,42,.08);
                transform: translateY(-1px);
            }

        .ac-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px;
        }

        .ac-ico {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .ac-name {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
        }

        .ac-type {
            font-size: 10.5px;
            color: #94a3b8;
        }

        .ac-metrics {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .ac-metric {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .ac-metric-header {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
        }

        .ac-metric-lbl {
            color: #64748b;
            font-weight: 500;
        }

        .ac-metric-val {
            font-weight: 700;
        }

        .ac-bar-bg {
            height: 4px;
            background: #f1f5f9;
            border-radius: 99px;
            overflow: hidden;
        }

        .ac-bar-fill {
            height: 100%;
            border-radius: 99px;
        }

        .ac-tags {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .ac-tag {
            padding: 2px 8px;
            border-radius: 5px;
            font-size: 10px;
            font-weight: 600;
        }

        /* ─── AI INSIGHTS ─── */
        .ins-grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 14px;
        }

        .ins-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 12px;
            padding: 16px 18px;
            display: flex;
            gap: 13px;
            align-items: flex-start;
            box-shadow: 0 1px 3px rgba(15,23,42,.04);
            transition: box-shadow .15s,transform .15s;
        }

            .ins-card:hover {
                box-shadow: 0 4px 16px rgba(15,23,42,.08);
                transform: translateY(-1px);
            }

        .ins-ico {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .ins-title {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .ins-desc {
            font-size: 12px;
            color: #64748b;
            line-height: 1.55;
        }

        .ins-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin-top: 8px;
            padding: 2px 8px;
            border-radius: 5px;
            font-size: 11px;
            font-weight: 600;
        }

        /* ─── PRESSURE WIDGETS ─── */
        .pressure-grid {
            display: grid;
            grid-template-columns: repeat(5,1fr);
            gap: 14px;
        }

        .pressure-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 12px;
            padding: 16px;
            box-shadow: 0 1px 3px rgba(15,23,42,.04);
            display: flex;
            flex-direction: column;
            gap: 10px;
            transition: box-shadow .15s;
        }

            .pressure-card:hover {
                box-shadow: 0 4px 14px rgba(15,23,42,.08);
            }

        .pc-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .pc-lbl {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: #94a3b8;
        }

        .pc-ico {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
        }

        .pc-val {
            font-size: 22px;
            font-weight: 800;
            letter-spacing: -.4px;
        }

        .pc-bar-bg {
            height: 5px;
            background: #f1f5f9;
            border-radius: 99px;
            overflow: hidden;
        }

        .pc-bar-fill {
            height: 100%;
            border-radius: 99px;
        }

        .pc-foot {
            font-size: 11px;
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* ─── TIMELINE ─── */
        .timeline-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(15,23,42,.05);
            overflow: hidden;
        }

        .timeline-head {
            padding: 14px 20px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fafbfd;
        }

        .timeline-title {
            font-size: 14px;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .timeline-title i {
                color: #2563eb;
            }

        .timeline-body {
            padding: 16px 20px;
        }

        .timeline-grid {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }

        .tl-day {
            width: 36px;
            height: 52px;
            border-radius: 7px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3px;
            cursor: default;
            transition: transform .13s;
            border: 1px solid transparent;
        }

            .tl-day:hover {
                transform: scale(1.08);
            }

        .tl-day-num {
            font-size: 11px;
            font-weight: 700;
        }

        .tl-day-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

        .tl-critical {
            background: #fef2f2;
            border-color: #fecaca;
        }

            .tl-critical .tl-day-num {
                color: #dc2626;
            }

            .tl-critical .tl-day-dot {
                background: #dc2626;
            }

        .tl-high {
            background: #fff7ed;
            border-color: #fed7aa;
        }

            .tl-high .tl-day-num {
                color: #ea580c;
            }

            .tl-high .tl-day-dot {
                background: #ea580c;
            }

        .tl-medium {
            background: #fffbeb;
            border-color: #fde68a;
        }

            .tl-medium .tl-day-num {
                color: #d97706;
            }

            .tl-medium .tl-day-dot {
                background: #d97706;
            }

        .tl-low {
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

            .tl-low .tl-day-num {
                color: #16a34a;
            }

            .tl-low .tl-day-dot {
                background: #16a34a;
            }

        .tl-legend {
            display: flex;
            gap: 14px;
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px solid #f1f5f9;
            flex-wrap: wrap;
        }

        .tll-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11.5px;
            color: #64748b;
        }

        .tll-box {
            width: 12px;
            height: 12px;
            border-radius: 3px;
            flex-shrink: 0;
        }

        /* ─── SECTION TITLE ─── */
        .ob-sec-title {
            font-size: 15px;
            font-weight: 700;
            color: #0f172a;
            margin: 0 0 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .ob-sec-title i {
                color: #2563eb;
                font-size: 14px;
            }

        .ob-sec-sub {
            font-size: 11px;
            font-weight: 500;
            color: #94a3b8;
            margin-left: 4px;
        }

        /* ─── RESPONSIVE ─── */
        @@media (max-width:1200px) {
            .kpi-grid {
                grid-template-columns: repeat(3,1fr);
            }

            .aircraft-grid {
                grid-template-columns: repeat(2,1fr);
            }

            .pressure-grid {
                grid-template-columns: repeat(3,1fr);
            }
        }

        @@media (max-width:900px) {
            .kpi-grid {
                grid-template-columns: repeat(2,1fr);
            }

            .ins-grid {
                grid-template-columns: repeat(2,1fr);
            }

            .fos-meta-sep {
                display: none;
            }

            .fos-meta-item {
                min-width: 130px;
                padding: 8px 10px;
            }
        }

        @@media (max-width:640px) {
            .kpi-grid {
                grid-template-columns: 1fr 1fr;
            }

            .ins-grid {
                grid-template-columns: 1fr;
            }

            .aircraft-grid {
                grid-template-columns: 1fr;
            }

            .pressure-grid {
                grid-template-columns: 1fr 1fr;
            }
        }
    </style>
}

<main class="main-content" id="main-content">
    <div class="container-fluid px-4 py-4">
        <div class="ob-page">

            @* ═══════ 1 — HEADER ═══════ *@
            <div class="ob-header">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1" style="font-size:12.5px;">
                            <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Dashboard</a></li>
                            <li class="breadcrumb-item active">Overbooking Control Center</li>
                        </ol>
                    </nav>
                    <h2 class="ob-title">AI Airline Risk Intelligence</h2>
                    <p class="ob-sub">
                        <i class="bi bi-robot me-1"></i>
                        Overbooking Control Center &bull; @Model.TotalFlightCount uçuş &bull; @Model.TotalPassengerCount yolcu
                    </p>
                </div>
                <div class="ob-actions">
                    <button class="ob-btn ob-btn-outline" onclick="exportCSV()"><i class="bi bi-download"></i> Export CSV</button>
                    <button class="ob-btn ob-btn-primary"><i class="bi bi-stars"></i> AI Risk Report</button>
                </div>
            </div>

            @* ═══════ 2 — FLIGHT OPERATION SUMMARY ═══════ *@
            <div class="fos-card">
                <div class="fos-top">
                    <div class="fos-route-wrap">
                        <div class="fos-airport">
                            <span class="fos-iata">SAW</span>
                            <span class="fos-apt-name">İstanbul Sabiha Gökçen</span>
                            <span class="fos-apt-country">Türkiye</span>
                        </div>
                        <div class="fos-connector">
                            <div class="fos-conn-line">
                                <span class="fos-conn-dot"></span>
                                <span class="fos-conn-dash"></span>
                                <i class="bi bi-airplane-fill fos-plane-ico"></i>
                                <span class="fos-conn-dash"></span>
                                <span class="fos-conn-dot"></span>
                            </div>
                            <div class="fos-conn-meta">
                                <span><i class="bi bi-clock me-1"></i>~2s 30dk</span>
                                <span><i class="bi bi-arrows-expand me-1"></i>1.380 km</span>
                            </div>
                        </div>
                        <div class="fos-airport fos-airport-right">
                            <span class="fos-iata">BGY</span>
                            <span class="fos-apt-name">Milano Bergamo</span>
                            <span class="fos-apt-country">İtalya</span>
                        </div>
                    </div>
                    <div class="fos-badges">
                        <span class="fos-badge fb-blue"><i class="bi bi-calendar3"></i> 2026 Yıllık</span>
                        <span class="fos-badge fb-green"><i class="bi bi-check-circle-fill"></i> Aktif Rota</span>
                        <span class="fos-badge fb-purple"><i class="bi bi-robot"></i> AI Aktif</span>
                        <span class="fos-badge fb-orange"><i class="bi bi-shield-exclamation"></i> Risk Monitörü</span>
                    </div>
                </div>
                <div class="fos-divider"></div>
                <div class="fos-meta-grid">
                    <div class="fos-meta-item">
                        <div class="fos-meta-ico" style="background:#eff6ff;color:#2563eb;"><i class="bi bi-calendar-range"></i></div>
                        <div class="fos-meta-body">
                            <span class="fos-meta-lbl">Analiz Dönemi</span>
                            <span class="fos-meta-val">01 Oca — 31 Ara 2026</span>
                            <span class="fos-meta-sub">365 günlük veri seti</span>
                        </div>
                    </div>
                    <div class="fos-meta-sep"></div>
                    <div class="fos-meta-item">
                        <div class="fos-meta-ico" style="background:#f0fdf4;color:#16a34a;"><i class="bi bi-airplane-engines-fill"></i></div>
                        <div class="fos-meta-body">
                            <span class="fos-meta-lbl">Günlük Operasyon</span>
                            <span class="fos-meta-val">4 Uçuş / Gün</span>
                            <div class="fos-chips">
                                <span class="fos-chip fc-morning">M1</span>
                                <span class="fos-chip fc-morning">M2</span>
                                <span class="fos-chip fc-evening">E1</span>
                                <span class="fos-chip fc-evening">E2</span>
                            </div>
                        </div>
                    </div>
                    <div class="fos-meta-sep"></div>
                    <div class="fos-meta-item">
                        <div class="fos-meta-ico" style="background:#f5f3ff;color:#7c3aed;"><i class="bi bi-database-fill"></i></div>
                        <div class="fos-meta-body">
                            <span class="fos-meta-lbl">Toplam Veri</span>
                            <span class="fos-meta-val">@Model.TotalFlightCount Kayıt</span>
                            <span class="fos-meta-sub">@Model.TotalPassengerCount yolcu</span>
                        </div>
                    </div>
                    <div class="fos-meta-sep"></div>
                    <div class="fos-meta-item">
                        <div class="fos-meta-ico" style="background:#fff7ed;color:#ea580c;"><i class="bi bi-cpu-fill"></i></div>
                        <div class="fos-meta-body">
                            <span class="fos-meta-lbl">AI Modülleri</span>
                            <div class="fos-chips">
                                <span class="fos-chip fc-ai">Forecasting</span>
                                <span class="fos-chip fc-ai">No-Show</span>
                                <span class="fos-chip fc-ai">Overbooking</span>
                            </div>
                        </div>
                    </div>
                    <div class="fos-meta-sep"></div>
                    <div class="fos-meta-item" style="flex:1.4;">
                        <div class="fos-meta-ico" style="background:#fef2f2;color:#dc2626;"><i class="bi bi-airplane-fill"></i></div>
                        <div class="fos-meta-body">
                            <span class="fos-meta-lbl">Kullanılan Filo</span>
                            <div class="fos-fleet">
                                <span class="fos-fleet-item"><i class="bi bi-dot"></i>Airbus A320</span>
                                <span class="fos-fleet-item"><i class="bi bi-dot"></i>Airbus A321</span>
                                <span class="fos-fleet-item"><i class="bi bi-dot"></i>Boeing 737 MAX</span>
                                <span class="fos-fleet-item"><i class="bi bi-dot"></i>A321neo HD</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* ═══════ 3 — KPI CARDS ═══════ *@
            <div class="kpi-grid">
                <div class="kpi-card kc-blue">
                    <div class="kpi-top">
                        <div class="kpi-lbl">Ort. No-Show</div>
                        <div class="kpi-ico" style="background:#eff6ff;color:#2563eb;"><i class="bi bi-percent"></i></div>
                    </div>
                    <div class="kpi-val">%@Model.AverageNoShowRate.ToString("0.0")</div>
                    <div class="kpi-foot">
                        <span class="kpi-bdg @(Model.AverageNoShowRate >= 7 ? "kb-red" : Model.AverageNoShowRate >= 5 ? "kb-orange" : "kb-green")">
                            @(Model.AverageNoShowRate >= 7 ? "Yüksek" : Model.AverageNoShowRate >= 5 ? "Orta" : "Kontrollü")
                        </span> tüm slotlar
                    </div>
                </div>
                <div class="kpi-card kc-red">
                    <div class="kpi-top">
                        <div class="kpi-lbl">En Riskli Slot</div>
                        <div class="kpi-ico" style="background:#fef2f2;color:#dc2626;"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    </div>
                    <div class="kpi-val-sm">@Model.MostRiskySlot</div>
                    <div class="kpi-foot"><span class="kpi-bdg kb-red"><i class="bi bi-fire" style="font-size:9px;"></i> Risk</span> kritik slot</div>
                </div>
                <div class="kpi-card kc-green">
                    <div class="kpi-top">
                        <div class="kpi-lbl">En Stabil Slot</div>
                        <div class="kpi-ico" style="background:#f0fdf4;color:#16a34a;"><i class="bi bi-shield-check-fill"></i></div>
                    </div>
                    <div class="kpi-val-sm">@Model.MostStableSlot</div>
                    <div class="kpi-foot"><span class="kpi-bdg kb-green"><i class="bi bi-check-lg" style="font-size:9px;"></i> Stabil</span> en düşük no-show</div>
                </div>
                <div class="kpi-card kc-orange">
                    <div class="kpi-top">
                        <div class="kpi-lbl">Overbooking Önerisi</div>
                        <div class="kpi-ico" style="background:#fffbeb;color:#d97706;"><i class="bi bi-airplane-fill"></i></div>
                    </div>
                    <div class="kpi-val">%@Model.SuggestedOverbookingRate.ToString("0.0")</div>
                    <div class="kpi-foot"><span class="kpi-bdg kb-orange"><i class="bi bi-info-circle" style="font-size:9px;"></i></span> önerilen oran</div>
                </div>
                <div class="kpi-card kc-purple">
                    <div class="kpi-top">
                        <div class="kpi-lbl">Toplam Yolcu</div>
                        <div class="kpi-ico" style="background:#f5f3ff;color:#7c3aed;"><i class="bi bi-people-fill"></i></div>
                    </div>
                    <div class="kpi-val" style="font-size:20px;">@Model.TotalPassengerCount.ToString("N0")</div>
                    <div class="kpi-foot"><span class="kpi-bdg kb-purple">2026</span> yıllık</div>
                </div>
                <div class="kpi-card kc-teal">
                    <div class="kpi-top">
                        <div class="kpi-lbl">Toplam Uçuş</div>
                        <div class="kpi-ico" style="background:#ecfeff;color:#0891b2;"><i class="bi bi-airplane-engines-fill"></i></div>
                    </div>
                    <div class="kpi-val">@Model.TotalFlightCount</div>
                    <div class="kpi-foot"><span class="kpi-bdg kb-teal">4 slot</span> günlük</div>
                </div>
            </div>

            @* ═══════ 4 — RISK HEATMAP ═══════ *@
            <div class="heatmap-card">
                <div class="heatmap-head">
                    <div class="heatmap-title"><i class="bi bi-grid-3x3-gap-fill"></i> Risk Heatmap — Slot x Hafta</div>
                    <div class="heatmap-legend">
                        <div class="hml-item"><div class="hml-dot" style="background:#f0fdf4;border:1px solid #bbf7d0;"></div> Düşük</div>
                        <div class="hml-item"><div class="hml-dot" style="background:#fffbeb;border:1px solid #fde68a;"></div> Orta</div>
                        <div class="hml-item"><div class="hml-dot" style="background:#fff7ed;border:1px solid #fed7aa;"></div> Yüksek</div>
                        <div class="hml-item"><div class="hml-dot" style="background:#fef2f2;border:1px solid #fecaca;"></div> Kritik</div>
                    </div>
                </div>
                <div class="heatmap-body">
                    @{
                        var slotNames = new[] { "Morning-1", "Morning-2", "Evening-1", "Evening-2" };
                        var weekLabels = new[] { "Hafta 1", "Hafta 2", "Hafta 3", "Hafta 4" };

                        string HmBg(double rate) => rate >= 8 ? "#fef2f2" : rate >= 6 ? "#fff7ed" : rate >= 4 ? "#fffbeb" : "#f0fdf4";
                        string HmColor(double rate) => rate >= 8 ? "#dc2626" : rate >= 6 ? "#ea580c" : rate >= 4 ? "#d97706" : "#16a34a";
                        string HmLbl(double rate) => rate >= 8 ? "Kritik" : rate >= 6 ? "Yüksek" : rate >= 4 ? "Orta" : "Düşük";
                    }
                    <div class="heatmap-grid">
                        <div></div>
                        @foreach (var sn in slotNames)
                        {
                            <div class="hm-col-header">@sn</div>
                        }
                        @for (int wi = 0; wi < 4; wi++)
                        {
                            <div class="hm-row-label">@weekLabels[wi]</div>
                            @for (int si = 0; si < slotNames.Length; si++)
                            {
                                var cellRows = Model.Recommendations?
                                .Where(r => r.FlightSlot == slotNames[si])
                                .Skip(wi * 7).Take(7).ToList();
                                double cr = (cellRows != null && cellRows.Any())
                                ? cellRows.Average(r => r.ExpectedNoShowRate)
                                : (Model.AverageNoShowRate + (si - 1.5) * 0.8 + (wi - 1.5) * 0.5);
                                <div class="hm-cell" style="background:@HmBg(cr);color:@HmColor(cr);">
                                    <span class="hm-cell-val">%@cr.ToString("0.0")</span>
                                    <span class="hm-cell-lbl">@HmLbl(cr)</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            @* ═══════ 5 — ANA TABLO ═══════ *@
            <div class="ob-table-card">
                <div class="ob-table-head">
                    <div class="ob-table-title"><i class="bi bi-table"></i> Overbooking Öneri Tablosu</div>
                    <span class="ob-rec-count" id="obRecCount">@(Model.Recommendations?.Count ?? 0) kayıt</span>
                </div>
                <div class="ob-filter-bar">
                    <span class="ob-chip active" onclick="obFilter('all',this)">Tümü</span>
                    <span class="ob-chip" onclick="obFilter('Critical',this)"><i class="bi bi-circle-fill" style="font-size:7px;color:#dc2626;"></i> Kritik</span>
                    <span class="ob-chip" onclick="obFilter('High',this)"><i class="bi bi-circle-fill" style="font-size:7px;color:#ea580c;"></i> Yüksek</span>
                    <span class="ob-chip" onclick="obFilter('Medium',this)"><i class="bi bi-circle-fill" style="font-size:7px;color:#d97706;"></i> Orta</span>
                    <span class="ob-chip" onclick="obFilter('Low',this)"><i class="bi bi-circle-fill" style="font-size:7px;color:#16a34a;"></i> Düşük</span>
                    <div class="ob-search">
                        <i class="bi bi-search"></i>
                        <input type="text" placeholder="Tarih / Slot..." oninput="obSearch(this.value)" />
                    </div>
                </div>
                <div style="overflow-x:auto;">
                    <table class="ob-table" id="obTable">
                        <thead>
                            <tr>
                                <th>Tarih</th>
                                <th>Slot</th>
                                <th>Boarded Passenger</th>
                                <th style="min-width:110px;">Kapasite</th>
                                <th>Bek. No-Show</th>
                                <th>Önerilen Satış</th>
                                <th>Ekstra Koltuk</th>
                                <th>Risk</th>
                                <th>AI Öneri</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Recommendations != null)
                            {
                                @foreach (var rec in Model.Recommendations)
                                {
                                    double capPct = rec.Capacity > 0 ? (double)rec.ActualPassengerCount / rec.Capacity * 100 : 0;
                                    string slotCls = rec.FlightSlot != null && rec.FlightSlot.StartsWith("Morning") ? "sp-morning" : "sp-evening";
                                    string slotIco = slotCls == "sp-morning" ? "bi-sunrise" : "bi-moon-stars";
                                    string dayName = "";
                                    if (DateTime.TryParse(rec.FlightDate, out DateTime fd))
                                        dayName = fd.ToString("ddd", new System.Globalization.CultureInfo("tr-TR"));

                                    <tr class="ob-row"
                                        data-risk="@rec.RiskLevel"
                                        data-search="@((rec.FlightDate ?? "") + " " + (rec.FlightSlot ?? ""))">
                                        <td>
                                            <div class="ob-date-cell">
                                                <span class="ob-date-main">@rec.FlightDate</span>
                                                <span class="ob-date-day">@dayName</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="slot-pill @slotCls">
                                                <i class="bi @slotIco" style="font-size:10px;"></i>
                                                @rec.FlightSlot
                                            </span>
                                        </td>
                                        <td><span style="color:#7c3aed;font-weight:600;">@(rec.ForecastPassengerCount.HasValue ? rec.ForecastPassengerCount.Value.ToString() : "—")</span></td>
                                        <td>
                                            <div class="cap-bar-wrap">
                                                <div class="cap-bar-bg">
                                                    <div class="cap-bar-fill" style="width:@Math.Min(capPct, 100).ToString("0", System.Globalization.CultureInfo.InvariantCulture)%;background:@(capPct >= 90 ? "#dc2626" : capPct >= 75 ? "#d97706" : "#2563eb");"></div>
                                                </div>
                                                <span style="font-size:11.5px;font-weight:700;color:#475569;min-width:30px;">@rec.Capacity</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="noshow-badge" style="background:@riskBg(rec.RiskLevel);color:@riskColor(rec.RiskLevel);border:1px solid @riskBorder(rec.RiskLevel);">
                                                @rec.ExpectedNoShowPassenger pax
                                            </span>
                                        </td>
                                        <td>
                                            <span class="rec-sale-pill">
                                                <i class="bi bi-ticket-perforated" style="font-size:10px;"></i>
                                                @rec.RecommendedMaxTicketSale
                                            </span>
