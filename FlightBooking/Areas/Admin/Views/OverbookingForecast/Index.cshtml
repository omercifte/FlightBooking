@model List<OverbookingForecastResultDto>

@{
    ViewData["Title"] = "2027 AI Overbooking Forecast Dashboard";
    Layout = "~/Areas/Admin/Views/Layout/AdminLayout.cshtml";

    @* ── Razor KPI Hesapları ── *@
    double avgNoShow = Model.Count > 0 ? Model.Average(r => r.PredictedNoShow) : 0;
    double avgExtra = Model.Count > 0 ? Model.Average(r => r.ExtraSeatCount) : 0;
    int totalExtra = Model.Sum(r => r.ExtraSeatCount);
    double totalRevenue = Model.Sum(r => r.EstimatedRevenue);
    int totalFlights = Model.Count;

    @* En riskli / güvenli slot *@
    var slotGroups = Model
        .GroupBy(r => r.FlightSlot)
        .Select(g => new { Slot = g.Key, AvgNS = g.Average(x => x.PredictedNoShow) })
        .OrderByDescending(x => x.AvgNS).ToList();
    string riskySlot = slotGroups.Any() ? slotGroups.First().Slot : "—";
    string safeSlot = slotGroups.Any() ? slotGroups.Last().Slot : "—";

    @* Risk yardımcıları *@
    Func<string, string> rc = (r) => r == "Critical" ? "#dc2626" : r == "High" ? "#ea580c" : r == "Medium" ? "#d97706" : "#16a34a";
    Func<string, string> rbg = (r) => r == "Critical" ? "#fef2f2" : r == "High" ? "#fff7ed" : r == "Medium" ? "#fffbeb" : "#f0fdf4";
    Func<string, string> rbd = (r) => r == "Critical" ? "#fecaca" : r == "High" ? "#fed7aa" : r == "Medium" ? "#fde68a" : "#bbf7d0";
    Func<string, string> rlb = (r) => r == "Critical" ? "Kritik" : r == "High" ? "Yüksek" : r == "Medium" ? "Orta" : "Düşük";
    Func<string, string> rio = (r) => r == "Critical" ? "bi-fire" : r == "High" ? "bi-exclamation-triangle-fill" : r == "Medium" ? "bi-dash-circle" : "bi-check-circle";

    @* Slot renk sistemi *@
    Func<string, string> slotColor = (s) =>
        s == "Morning-1" ? "#2563eb" :
        s == "Morning-2" ? "#0891b2" :
        s == "Evening-1" ? "#7c3aed" :
        s == "Evening-2" ? "#a21caf" : "#475569";
    Func<string, string> slotBg = (s) =>
        s == "Morning-1" ? "#eff6ff" :
        s == "Morning-2" ? "#ecfeff" :
        s == "Evening-1" ? "#f5f3ff" :
        s == "Evening-2" ? "#fdf4ff" : "#f8fafc";
    Func<string, string> slotBd = (s) =>
        s == "Morning-1" ? "#bfdbfe" :
        s == "Morning-2" ? "#a5f3fc" :
        s == "Evening-1" ? "#ddd6fe" :
        s == "Evening-2" ? "#f0abfc" : "#e2e8f0";
    Func<string, string> slotIcon = (s) =>
        s.StartsWith("Morning") ? "bi-sunrise-fill" : "bi-moon-stars-fill";

    @* Uçak badge rengi *@
    Func<string, string> aircraftColor = (a) =>
        a != null && a.Contains("A321") ? "#0891b2" :
        a != null && a.Contains("A320") ? "#2563eb" :
        a != null && a.Contains("737") ? "#ea580c" : "#7c3aed";
    Func<string, string> aircraftBg = (a) =>
        a != null && a.Contains("A321") ? "#ecfeff" :
        a != null && a.Contains("A320") ? "#eff6ff" :
        a != null && a.Contains("737") ? "#fff7ed" : "#f5f3ff";
}

